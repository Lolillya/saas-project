{
  "ReverseProxy": {
    "Routes": {
      "identity-public-route": {
        "ClusterId": "identity-cluster",
        "AuthorizationPolicy": "anonymous",
        "RateLimiterPolicy": "auth-limit",
        "Match": { "Path": "/identity/auth/{**catch-all}" },
        "Transforms": [{ "PathRemovePrefix": "/identity" }]
      },
      "identity-route": {
        "ClusterId": "identity-cluster",
        "AuthorizationPolicy": "default",
        "Match": { "Path": "/identity/{**catch-all}" },
        "Transforms": [{ "PathRemovePrefix": "/identity" }]
      }
    },
    "Clusters": {
      "identity-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "https://inventorysaas-identity-api.azurewebsites.net/"
          }
        }
      }
    }
  },
  "ApplicationInsights": {
    "ConnectionString": "InstrumentationKey=00000000-0000-0000-0000-000000000000;IngestionEndpoint=https://westeurope-1.in.applicationinsights.azure.com/;LiveEndpoint=https://westeurope.livediagnostics.monitor.azure.com/"
  },
  "JwtSettings": {
    "Key": "my-super-secret-key-for-jwt-token-generation",
    "Issuer": "InventorySaaS.Identity",
    "Audience": "InventorySaaS"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
