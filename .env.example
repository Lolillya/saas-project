# Azure SQL Connection
# ConnectionStrings__IdentityDb maps to ConnectionStrings:IdentityDb in ASP.NET config
ConnectionStrings__IdentityDb="Server=tcp:<your-server>.database.windows.net,1433;Initial Catalog=<your-db>;Persist Security Info=False;User ID=<your-user>;Password=<your-password>;MultipleActiveResultSets=False;Encrypt=True;TrustServerCertificate=False;Connection Timeout=30;"
# JWT Secret — JwtSettings__Key maps to JwtSettings:Key in ASP.NET config
JwtSettings__Key="<replace-with-a-strong-random-secret-min-32-chars>"